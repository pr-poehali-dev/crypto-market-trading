{
  "tests": [
    {
      "name": "OPTIONS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "email": "test_cryptox@example.com", "password": "test123456", "name": "Тест Пользователь"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login existing user",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "test_cryptox@example.com", "password": "test123456"},
      "expectedStatus": 200,
      "expectedBody": {"token": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Login wrong password",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "test_cryptox@example.com", "password": "wrongpass"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
